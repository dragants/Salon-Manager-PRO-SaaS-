NODE_ENV=development
PORT=5000
# Rate limit: vrednosti su u src/config/rate-limits.js (auth / global).
# Slušaj na LAN-u (Wi‑Fi / Ethernet). Podrazumevano je već 0.0.0.0 u kodu.
# HOST=0.0.0.0
# Lokalno sa Dockerom (vidi ../docker-compose.yml):
DATABASE_URL=postgresql://salon:salon_dev@localhost:5432/salon_manager
# Ili svoj PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/salon_manager
# Min. 32 znaka u produkciji (server ne startuje bez ovoga kada je NODE_ENV=production).
JWT_SECRET=dev_only_replace_with_long_random_string_at_least_32_chars

# CORS + httpOnly JWT kolačić: tačan URL frontenda (više vrednosti odvoj zarezom, npr. LAN + localhost).
FRONTEND_URL=http://localhost:3000
# Produkcija: dodatni dozvoljeni origini (zarezom), pored FRONTEND_URL i LAN localhost.
# Primer — zameni domen:
# CORS_ORIGINS=https://tvoj-domen.com,https://app.tvoj-domen.com
# Produkcija HTTPS: obavezno Secure kolačić (podrazumevano iz NODE_ENV).
# COOKIE_SECURE=true
# Ako proxy terminira TLS a Node vidi HTTP: COOKIE_INSECURE=true (samo posebni slučaj).

# Folder za priloge kartona klijenata: uploads/{orgId}/clients/{clientId}/
# UPLOAD_ROOT=uploads

TWILIO_SID=
TWILIO_TOKEN=
TWILIO_PHONE=

WA_TOKEN=
WA_PHONE_ID=

# Redis (Bull queue)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
# REDIS_PASSWORD=
# Alternative:
# REDIS_URL=redis://:password@127.0.0.1:6379
# Disable Redis completely (dev/test):
# REDIS_DISABLED=true

# Samo development: isključi rate-limit na /auth/login (loginProtection) kad te zaključa posle testiranja 2FA.
# Produkcija ignoriše ovo (mora NODE_ENV=production).
# LOGIN_PROTECTION_DISABLED=true

# false da se queue isključi i šalje direktno (fallback)
NOTIFICATIONS_QUEUE_ENABLED=true

# Podrazumevana IANA zona ako firma nema settings.timezone (poruke + podsetnici)
APP_TIMEZONE=Europe/Belgrade

# false da isključiš sve cron podsetnike
REMINDERS_ENABLED=true

# Podrazumevani sat (0–23) za “sutra imate termin” ako firma nema settings.reminders.dayBeforeHour
REMINDER_DAY_BEFORE_HOUR=17

# Paddle Classic (pretplata) — Seller Dashboard → Developer Tools
# PADDLE_VENDOR_ID=12345
# PADDLE_API_KEY=vendor_auth_code
# PADDLE_PRODUCT_ID=123456
# Javni ključ za proveru webhook potpisa (Developer Tools → Public Key)
# PADDLE_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----
# Lokalno bez javnog HTTPS: PADDLE_WEBHOOK_SKIP_VERIFY=true (samo dev)
# FRONTEND_URL=http://localhost:3000
# Webhook URL u Paddle: https://tvoj-backend/webhooks/paddle
# SUBSCRIPTION_ENFORCED=false

# Limiti klijenata po planu (besplatno vs aktivna pretplata active/trialing)
# PLAN_LIMITS_ENFORCED=false
# FREE_TIER_MAX_CLIENTS=50
# PAID_TIER_MAX_CLIENTS=10000
# FREE_TIER_MAX_APPOINTMENTS_PER_MONTH=200
# PAID_TIER_MAX_APPOINTMENTS_PER_MONTH=100000
# BASIC_TIER_MAX_CLIENTS=500
# PRO_TIER_MAX_CLIENTS=10000
# BASIC_TIER_MAX_APPOINTMENTS_PER_MONTH=2000
# PRO_TIER_MAX_APPOINTMENTS_PER_MONTH=100000
# Paddle: ID-jevi Pro proizvoda/planova (odvojeni zarez) za automatski billing_plan = pro
# PADDLE_PRO_PRODUCT_IDS=

# Stripe (SaaS billing - optional, parallel to Paddle)
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# STRIPE_PRICE_ID=
# STRIPE_SUCCESS_URL=
# STRIPE_CANCEL_URL=
# STRIPE_PORTAL_RETURN_URL=
# Optional mapping (if you want webhook to map plans by price id):
# STRIPE_PRICE_ID_BASIC=
# STRIPE_PRICE_ID_PRO=

# Web Push (PWA) — generiši: npx web-push generate-vapid-keys
# VAPID_SUBJECT=mailto:tvoj@email.com
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# Šalji push kad klijent zakazuje preko /book: dodeljenom radniku, ili ako nema radnika — administratorima.
# PUSH_NOTIFY_NEW_BOOKING=true
# Uz dodeljenog radnika, obavesti i administratore (dupla notifikacija).
# PUSH_NOTIFY_ADMINS_TOO=false
